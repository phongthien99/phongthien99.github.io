&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="w"> &lt;/span>&lt;span class="l">Describe(&amp;#34;UserService&amp;#34;, func() {&lt;/span>&lt;span class="w">
