&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="w"> &lt;/span>&lt;span class="l">Expect(userService).NotTo(BeNil())&lt;/span>&lt;span class="w">
