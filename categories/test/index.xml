&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="w"> &lt;/span>&lt;span class="l">It(&amp;#34;should create a new user successfully&amp;#34;, func() {&lt;/span>&lt;span class="w">
